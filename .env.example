# .env.example — copy to .env and fill in your values

# PostgreSQL connection string — e.g. postgresql://user:password@host:5432/dbname (leave empty to use SQLite)
DATABASE_URL=

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Backend API URL for the React frontend
VITE_API_URL=http://localhost:8000
